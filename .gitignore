# --- OS / editor ---
.DS_Store
.AppleDouble
._*
.Spotlight-V100
.Trashes

.cursor/

.vscode/
.idea/

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
dist/
build/
*.egg-info/

# --- Environments ---
.env
.venv/
venv/
ENV/

# --- Jupyter ---
.ipynb_checkpoints/

# --- Local secrets / config ---
*.pem
*.key
*.p12
*.pfx

# --- Model weights / checkpoints (large) ---
/models/
*.safetensors
*.bin
*.pt
*.pth
*.ckpt
*.gguf
*.onnx

# Keep the python package `src/models/` tracked, but ignore any weight folders
# that may be placed inside it locally (e.g., src/models/llama2-7b/).
src/models/*/
!src/models/__init__.py
!src/models/wrapper.py

# --- Preprocessed datasets (can be huge; keep out of git) ---
datasets/**
!datasets/.gitkeep
# Allow committing the (small) MedQA dataset folder.
!datasets/medqa/
!datasets/medqa/**
# But keep OS junk out of that folder.
datasets/medqa/**/.DS_Store
datasets/medqa/**/.AppleDouble
datasets/medqa/**/._*

# --- Data (allow small inputs, ignore typical large subdirs) ---
data/raw/*
data/processed/
data/cache/
data/tmp/
data/downloads/
!data/.gitkeep

# Allow committing the small CrowS-Pairs CSV for portability.
!data/raw/crows_pairs.csv
!data/raw/medqa_demographic_audit.csv

# --- Run outputs (generated) ---
results/**
!results/.gitkeep

# --- Alternative run root (some pipelines may use this) ---
runs/

# --- Figures (often lightweight enough to commit; keep allowed by default) ---
!figures/.gitkeep

# --- Numpy / arrays (large) ---
*.npz
*.npy
*.np

# --- Common large archives ---
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar

# --- Logs ---
*.log

# --- Local agent notes ---
CLAUDE.md

